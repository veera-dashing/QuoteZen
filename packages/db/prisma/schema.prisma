model Client {
  id              BigInt   @id @default(autoincrement())
  name            String
  marginNote      String?  @map("margin_note")
  ledScreenNote   String?  @map("led_screen_note")
  gobNote         String?  @map("gob_note")
  mediaplayerNote String?  @map("mediaplayer_note")
  ratioNote       String?  @map("ratio_note")
  defaultMargin   Decimal? @map("default_margin") @db.Decimal(8, 4)
  // Structured overrides (P1-10) — replace today's free-text notes.
  preferredProductFamily String? @map("preferred_product_family")
  preferredPitchMm       Decimal? @map("preferred_pitch_mm") @db.Decimal(6, 3)
  /** Comma-separated component/family names to exclude for this client. */
  excludedComponents     String? @map("excluded_components")
  /**
   * Client-level commercial discount (U0), a fraction 0..1 (e.g. 0.05 = 5%). Resolution order is
   * system default (`default_client_discount_pct` setting) → client → quote override. NOT applied to
   * pricing yet — U0 only stores it + defaults it from the setting at client create.
   */
  discountPct            Decimal? @map("discount_pct") @db.Decimal(5, 4)
  /**
   * Commercial client tier (Z1). Free-text nullable String ('A' | 'A+' | 'B' | 'C' | null) rather than
   * an enum. From Z6 this string is a relation-by-name FK into `client_tiers.name` (see clientTier).
   */
  tier                   String?  @map("tier")
  /** Free-text per-client rule logic (Z6), surfaced on the Tiers & per-client rules admin page. */
  rulesNote              String?  @map("rules_note")
  /** Per-client preferred freight override (Z6) — wins over the tier's `preferredFreight`. */
  preferredFreight       String?  @map("preferred_freight")
  /**
   * AA2 — CSV of allowed aspect-ratio labels for this client (e.g. "16:9,9:16,6:1"). When non-empty,
   * the config engine only offers configurations whose achieved ratio label is in this set, and a
   * stored screen whose ratio is outside it is flagged (RATIO_NOT_ALLOWED, warning). Empty/null → no
   * restriction.
   */
  allowedRatios          String?  @map("allowed_ratios")
  /**
   * AA6a — free-text "this customer typically selects…" note, surfaced on the recommended G/B/B tier
   * card so estimators see the client's usual choice. Advisory caption only; no pricing effect.
   */
  typicalSelectionNote   String?  @map("typical_selection_note")
  /** Z6: rule-bearing tier resolved by name (clients.tier → client_tiers.name). */
  clientTier             ClientTier? @relation("ClientTierByName", fields: [tier], references: [name])

  quotes Quote[]

  @@map("clients")
}

// ── Z6: client tiers as rule-bearing entities ──
// Tier-level structured rules (preferred freight + default discount %) shared by all clients in the
// tier, overridable per client. Resolution order: global/system → tier → client. `name` matches the
// `clients.tier` string (relation-by-name; @unique required).
model ClientTier {
  id                 BigInt   @id @default(autoincrement())
  name               String   @unique // 'A+' | 'A' | 'B' (matches clients.tier)
  label              String?
  description        String?
  installStandard    String?  @map("install_standard")
  preferredFreight   String?  @map("preferred_freight")
  defaultDiscountPct Decimal? @map("default_discount_pct") @db.Decimal(5, 4)
  deprecated         Boolean  @default(false)
  clients            Client[] @relation("ClientTierByName")

  @@map("client_tiers")
}

// ── Z1: engine constraints & systemic rules — anomaly detection rules ──
// Admin-configurable rules that later blocks will evaluate against a quote (block vs warn). Z1 is
// schema + seed + admin-registry only; nothing consumes these rows yet.
model AnomalyRule {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(true)
  severity    String   @default("warn") // 'block' | 'warn'
  paramNum    Decimal? @map("param_num") @db.Decimal(12, 2)
  paramText   String?  @map("param_text")
  deprecated  Boolean  @default(false)

  @@map("anomaly_rules")
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP C — Quote transactional
// ════════════════════════════════════════════════════════════════════════════════
model Quote {
  id                    BigInt      @id @default(autoincrement())
  jobReference          String      @unique @map("job_reference")
  clientId              BigInt?     @map("client_id")
  locationId            BigInt?     @map("location_id")
  currencyId            BigInt      @map("currency_id")
  status                QuoteStatus @default(draft)
  resellerMarkup        Decimal     @default(0) @map("reseller_markup") @db.Decimal(8, 4)
  /** Optimistic-locking token; bumped on every mutation (P1-05.2). */
  lockVersion           Int         @default(0) @map("lock_version")
  validUntil            DateTime?   @map("valid_until")
  requestedShippingDate DateTime?   @map("requested_shipping_date")
  /** Quote-level discount OVERRIDE (U0), a fraction 0..1; wins over the client/system default. Not yet applied to pricing. */
  discountPct           Decimal?    @map("discount_pct") @db.Decimal(5, 4)
  /** Where the discount applies (U5): `one_off` = the upfront equipment+services concession; `recurring` = every renewal (the recurring total). */
  discountScope         String      @default("one_off") @map("discount_scope")
  /** How per-line discounts interact with the quote/client discount (V2): `stack` = both apply; `item_only` = the quote/client discount is suppressed when any per-line discount exists. */
  discountMode          String      @default("stack") @map("discount_mode")
  /** Manager justification note for the quote-level discount. Required when the discount exceeds `discount_note_threshold_pct` (default 5%); the hard cap is `discount_cap_pct` (default 12%, admin-overridable). */
  discountNote          String?     @map("discount_note")
  /** Quote-wide PI capture (U0): the install site address and free-text project notes. */
  siteAddress           String?     @map("site_address")
  projectNotes          String?     @map("project_notes")
  // AA1 — site/context intake fields (one-per-quote site details from the workshop intake questionnaire).
  /** The end customer / where it's installed (distinct from the buying `client`). */
  endCustomer           String?     @map("end_customer")
  /** Airside / Landside / N/A — relevant for airport & secure-zone sites. */
  airsideLandside       String?     @map("airside_landside")
  /** Sun exposure at the install location: None / Indirect / Direct (affects brightness suitability). */
  sunExposure           String?     @map("sun_exposure")
  /** Wall substrate free-text (e.g. plasterboard, brick, concrete) — drives fixing method. */
  wallSubstrate         String?     @map("wall_substrate")
  /** Whether power & data are available at the location: Yes / No / Unknown. */
  powerDataAvailable    String?     @map("power_data_available")
  /** Where the controller / media-player will live (free text). */
  controllerLocation    String?     @map("controller_location")
  /** Window-facing / glare risk flag. */
  windowFacing          Boolean?    @map("window_facing")
  // AA5 — software/hardware dependency intake fields (Group E). Descriptive; feed the PM handoff + solution summary; no pricing impact.
  /** Who supplies the media player: 'Seen' / 'Client-supplied' / 'Mandated'. */
  mediaPlayerSupply     String?     @map("media_player_supply")
  /** Shared-device ratio — N players … (paired with sharedDeviceScreens). */
  sharedDevicePlayers   Int?        @map("shared_device_players")
  /** Shared-device ratio — … per M screens (paired with sharedDevicePlayers). */
  sharedDeviceScreens   Int?        @map("shared_device_screens")
  /** Store size (m²) — drives music-service sizing. */
  storeSizeSqm          Decimal?    @map("store_size_sqm") @db.Decimal(10, 2)
  /** Custom content curation required. */
  customContentCuration Boolean?    @map("custom_content_curation")
  /** A PC dependency beyond the per-LCD-screen flag. */
  pcRequired            Boolean?    @map("pc_required")
  /** A hard-drive dependency. */
  hardDriveRequired     Boolean?    @map("hard_drive_required")
  // AA6a — commercial intake fields (Group F, no-pricing-risk parts). Descriptive/advisory only; they
  // drive recommendation emphasis + advisory findings + the PM handoff — never pricing math.
  /** Client's price posture: 'budget' | 'balanced' | 'premium' — emphasises the matching G/B/B tier. */
  priceSensitivity      String?     @map("price_sensitivity")
  /** Indicative budget (AUD) — captured for context (advisory; not a pricing input). */
  budgetAud             Decimal?    @map("budget_aud") @db.Decimal(12, 2)
  /** Expected engagement tenure (months) — commercial context. */
  tenureMonths          Int?        @map("tenure_months")
  /** Free-text "must have" requirements — folded into the assumptions/register as assumed-but-not-quoted. */
  clientMustHaves       String?     @map("client_must_haves")
  /** Whether a solutions engineer review is requested (also triggered by a large screen count). */
  needsSolutionsEngineer Boolean?   @map("needs_solutions_engineer")
  /** Soft-delete / archive timestamp (P1-05.1); null = active. The row is never hard-deleted. */
  archivedAt            DateTime?   @map("archived_at")
  estimatedCost         Decimal?    @map("estimated_cost") @db.Decimal(12, 2)
  actualCost            Decimal?    @map("actual_cost") @db.Decimal(12, 2)
  totalEquipment        Decimal     @default(0) @map("total_equipment") @db.Decimal(12, 2)
  totalServices         Decimal     @default(0) @map("total_services") @db.Decimal(12, 2)
  totalRecurring        Decimal     @default(0) @map("total_recurring") @db.Decimal(12, 2)
  grandTotal            Decimal     @default(0) @map("grand_total") @db.Decimal(12, 2)
  createdById           BigInt      @map("created_by")
  updatedById           BigInt?     @map("updated_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  client    Client?   @relation(fields: [clientId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  currency  Currency  @relation(fields: [currencyId], references: [id])
  createdBy User      @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  updatedBy User?     @relation("QuoteUpdatedBy", fields: [updatedById], references: [id])

  kbEntry            KbEntry?
  viewers            QuoteViewer[]
  ledScreens         QuoteLedScreen[]
  lcdScreens         QuoteLcdScreen[]
  mediaplayers       QuoteMediaplayer[]
  peripherals        QuotePeripheral[]
  manufacturedItems  QuoteManufacturedItem[]
  audioItems         QuoteAudioItem[]
  musicItems         QuoteMusicItem[]
  hypervsnItems      QuoteHypervsnItem[]
  softwareItems      QuoteSoftwareItem[]
  licences           QuoteLicence[]
  terms              QuoteTerm[]
  risks              QuoteRisk[]
  auditLogs          QuoteAuditLog[]
  revisions          QuoteRevision[]
  reviews            QuoteReview[]
  overrides          QuoteOverride[]
  documents          QuoteDocument[]

  @@index([clientId])
  @@index([status])
  @@map("quotes")
}

/**
 * Per-job uploaded file (P1-19e). Bytes live on local disk under `storedName` (a generated,
 * collision-free name); this row is the metadata + version record. Re-uploading the same
 * `originalName` on a quote increments `version` — earlier versions are preserved.
 */
model QuoteDocument {
  id           BigInt   @id @default(autoincrement())
  quoteId      BigInt   @map("quote_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  version      Int      @default(1)
  uploadedById BigInt   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  quote      Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation("QuoteDocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([quoteId])
  @@map("quote_documents")
}

/**
 * Manual price override pinned as an input (P1-17). An overridden value pins, the engine recomputes
 * everything downstream from it, and any affected line is flagged. One active override per
 * (quote, targetType, targetId, field). `targetType` is open-ended so more override targets can be
 * added later (start: 'led_screen_price', targetId = the LED screen id).
 */
model QuoteOverride {
  id            BigInt   @id @default(autoincrement())
  quoteId       BigInt   @map("quote_id")
  targetType    String   @map("target_type")
  targetId      BigInt?  @map("target_id")
  fieldName     String   @map("field_name")
  /** The computed value at the moment the override was set (for the flag/diff + audit). */
  originalValue Decimal  @map("original_value") @db.Decimal(12, 2)
  overrideValue Decimal  @map("override_value") @db.Decimal(12, 2)
  reason        String?
  createdById   BigInt   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  quote     Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  createdBy User  @relation("QuoteOverrideCreatedBy", fields: [createdById], references: [id])

  @@unique([quoteId, targetType, targetId, fieldName])
  @@index([quoteId])
  @@map("quote_overrides")
}

model QuoteLedScreen {
  id                  BigInt   @id @default(autoincrement())
  quoteId             BigInt   @map("quote_id")
  seq                 Int      @default(1)
  sortOrder           Int      @default(0) @map("sort_order")
  screenName          String?  @map("screen_name")
  ledProductId        BigInt?  @map("led_product_id")
  qty                 Int      @default(1)
  desiredWidthMm      Int?     @map("desired_width_mm")
  desiredHeightMm     Int?     @map("desired_height_mm")
  rotateCabinets      Boolean  @default(false) @map("rotate_cabinets")
  // LED-1 input fields (S0): orientation/aspect drive UI auto-calc; back_cover may later feed pricing.
  orientation         String?  @map("orientation")
  aspectRatioId       BigInt?  @map("aspect_ratio_id")
  backCover           Boolean  @default(false) @map("back_cover")
  frameNote           String?  @map("frame_note")
  serviceDescriptionSuffix String? @map("service_description_suffix")
  // AA2 — content-ratio + supplier + flatness (descriptive; content ratio also feeds a validation rule).
  /** AA2 — the aspect ratio the CONTENT is authored for (e.g. "16:9"). Mismatch vs the achieved screen
      ratio → CONTENT_RATIO_MISMATCH (warning). Null → no check. */
  contentRatio        String?  @map("content_ratio")
  /** AA2 — who supplies the content (descriptive; surfaced in the PM handoff). */
  contentSupplier     String?  @map("content_supplier")
  /** AA2 — flatness is critical for this screen (descriptive; feeds a product-selection note). */
  flatnessRequired    Boolean? @map("flatness_required")
  gobId               BigInt?  @map("gob_id")
  // AA4 — protective/gold coating (priced by area) + high-resolution supply upgrade (fractional uplift).
  coatingId           BigInt?  @map("coating_id")
  highResolution      Boolean? @map("high_resolution")
  frameId             BigInt?  @map("frame_id")
  trimId              BigInt?  @map("trim_id")
  hangingBarId        BigInt?  @map("hanging_bar_id")
  engineeringId       BigInt?  @map("engineering_id")
  installMethodId     BigInt?  @map("install_method_id")
  freightOptionId     BigInt?  @map("freight_option_id")
  warrantyId          BigInt?  @map("warranty_id")
  serviceHoursId      BigInt?  @map("service_hours_id")
  accessEquipmentId   BigInt?  @map("access_equipment_id")
  marginOverride      Decimal? @map("margin_override") @db.Decimal(8, 4)
  // computed PI / spec outputs
  resolutionWpx       Int?     @map("resolution_w_px")
  resolutionHpx       Int?     @map("resolution_h_px")
  totalPixels         BigInt?  @map("total_pixels")
  weightKg            Decimal? @map("weight_kg") @db.Decimal(10, 2)
  powerAvgW           Int?     @map("power_avg_w")
  powerMaxW           Int?     @map("power_max_w")
  heatAvgBtu          Int?     @map("heat_avg_btu")
  heatMaxBtu          Int?     @map("heat_max_btu")
  cabinetDepthMm      Int?     @map("cabinet_depth_mm")
  recessSize          String?  @map("recess_size")
  /** AA1 — recess/cavity depth in mm (complements the front/rear `serviceAccess`). */
  recessDepthMm       Int?     @map("recess_depth_mm")
  freightKg           Decimal? @map("freight_kg") @db.Decimal(10, 2)
  labourHours         Decimal? @map("labour_hours") @db.Decimal(8, 2)
  // per-screen PI fields
  spareModulesPct     Decimal? @map("spare_modules_pct") @db.Decimal(6, 2)
  spareHubCard        Int?     @map("spare_hub_card")
  sparePowerSupply    Int?     @map("spare_power_supply")
  powerSupplySpec     String?  @map("power_supply_spec")
  cabinetSizes        String?  @map("cabinet_sizes")
  protectivePackage   String?  @map("protective_package")
  gobCoatingNote      String?  @map("gob_coating_note")
  bracketsNote        String?  @map("brackets_note")
  controllerSeenRef   String?  @map("controller_seen_ref")
  ledSize             String?  @map("led_size")
  dataSpec            String?  @map("data_spec")
  serviceAccess       String?  @map("service_access")
  physicalInstall     String?  @map("physical_install")
  powerAndData        String?  @map("power_and_data")
  estimatedCost       Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost          Decimal? @map("actual_cost") @db.Decimal(12, 2)
  // computed price outputs
  priceScreenMediaplayer Decimal? @map("price_screen_mediaplayer") @db.Decimal(12, 2)
  priceFrameTrim         Decimal? @map("price_frame_trim") @db.Decimal(12, 2)
  priceServices          Decimal? @map("price_services") @db.Decimal(12, 2)
  priceTotal             Decimal? @map("price_total") @db.Decimal(12, 2)

  quote           Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  // Catalog FKs are Restrict (P1-08.4 / P1-11.4): a saved quote pins its referenced catalog rows so
  // the price snapshot stays meaningful — deleting a referenced row is blocked (→ deprecate instead).
  ledProduct      LedProduct?         @relation(fields: [ledProductId], references: [id], onDelete: Restrict)
  aspectRatio     ScreenRatio?        @relation(fields: [aspectRatioId], references: [id], onDelete: Restrict)
  gob             GobOption?          @relation(fields: [gobId], references: [id], onDelete: Restrict)
  coating         CoatingOption?      @relation(fields: [coatingId], references: [id], onDelete: Restrict)
  frame           Frame?              @relation(fields: [frameId], references: [id], onDelete: Restrict)
  trim            TrimOption?         @relation(fields: [trimId], references: [id], onDelete: Restrict)
  hangingBar      HangingBarOption?   @relation(fields: [hangingBarId], references: [id], onDelete: Restrict)
  engineering     EngineeringOption?  @relation(fields: [engineeringId], references: [id], onDelete: Restrict)
  installMethod   InstallMethod?      @relation(fields: [installMethodId], references: [id], onDelete: Restrict)
  freightOption   FreightOption?      @relation(fields: [freightOptionId], references: [id], onDelete: Restrict)
  warranty        WarrantyOption?     @relation(fields: [warrantyId], references: [id], onDelete: Restrict)
  serviceHours    ServiceHoursOption? @relation(fields: [serviceHoursId], references: [id], onDelete: Restrict)
  accessEquipment AccessEquipment?    @relation(fields: [accessEquipmentId], references: [id], onDelete: Restrict)

  components     QuoteLedComponent[]
  costBreakdown  QuoteLedCostBreakdown[]

  @@index([quoteId])
  @@map("quote_led_screens")
}

model QuoteLedComponent {
  id               BigInt           @id @default(autoincrement())
  quoteLedScreenId BigInt           @map("quote_led_screen_id")
  componentType    LedComponentType @map("component_type")
  controllerId     BigInt?          @map("controller_id")
  ledPeripheralId  BigInt?          @map("led_peripheral_id")
  mediaplayerId    BigInt?          @map("mediaplayer_id")
  peripheralId     BigInt?          @map("peripheral_id")
  qty              Int              @default(1)
  unitCostSnapshot Decimal?         @map("unit_cost_snapshot") @db.Decimal(12, 2)
  unitSellSnapshot Decimal?         @map("unit_sell_snapshot") @db.Decimal(12, 2)

  screen        QuoteLedScreen @relation(fields: [quoteLedScreenId], references: [id], onDelete: Cascade)
  controller    Controller?    @relation(fields: [controllerId], references: [id], onDelete: Restrict)
  ledPeripheral LedPeripheral? @relation(fields: [ledPeripheralId], references: [id], onDelete: Restrict)
  mediaplayer   Mediaplayer?   @relation(fields: [mediaplayerId], references: [id], onDelete: Restrict)
  peripheral    Peripheral?    @relation(fields: [peripheralId], references: [id], onDelete: Restrict)

  @@index([quoteLedScreenId])
  @@map("quote_led_components")
}

model QuoteLedCostBreakdown {
  id               BigInt   @id @default(autoincrement())
  quoteLedScreenId BigInt   @map("quote_led_screen_id")
  lineLabel        String   @map("line_label")
  category         String?
  cost             Decimal? @db.Decimal(12, 2)
  sell             Decimal? @db.Decimal(12, 2)
  /** Per-line discount (V2), a fraction 0..1 that reduces this line's SELL in the rollup + margin. Null = no discount. */
  discountPct      Decimal? @map("discount_pct") @db.Decimal(5, 4)

  screen QuoteLedScreen @relation(fields: [quoteLedScreenId], references: [id], onDelete: Cascade)

  @@index([quoteLedScreenId])
  @@map("quote_led_cost_breakdown")
}

model QuoteLcdScreen {
  id                     BigInt   @id @default(autoincrement())
  quoteId                BigInt   @map("quote_id")
  seq                    Int      @default(1)
  sortOrder              Int      @default(0) @map("sort_order")
  screenName             String?  @map("screen_name")
  orientation            String?  @map("orientation")
  displayId              BigInt?  @map("display_id")
  installMethodId        BigInt?  @map("install_method_id")
  serviceHoursId         BigInt?  @map("service_hours_id")
  warrantyId             BigInt?  @map("warranty_id")
  /** AA1 — recess/cavity depth in mm (site-prep detail). */
  recessDepthMm          Int?     @map("recess_depth_mm")
  /** AA3a — site/requirement fields feeding the LCD selection rules (all nullable). */
  requiresAndroid        Boolean? @map("requires_android")
  maxDepthMm             Int?     @map("max_depth_mm")
  needsPc                Boolean? @map("needs_pc")
  needsHardDrive         Boolean? @map("needs_hard_drive")
  priceScreenMediaplayer Decimal? @map("price_screen_mediaplayer") @db.Decimal(12, 2)
  priceBracketShroud     Decimal? @map("price_bracket_shroud") @db.Decimal(12, 2)
  priceServices          Decimal? @map("price_services") @db.Decimal(12, 2)
  priceTotal             Decimal? @map("price_total") @db.Decimal(12, 2)
  labourHours            Decimal? @map("labour_hours") @db.Decimal(8, 2)
  dataSpec               String?  @map("data_spec")
  serviceAccess          String?  @map("service_access")
  physicalInstall        String?  @map("physical_install")
  powerAndData           String?  @map("power_and_data")
  estimatedCost          Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost             Decimal? @map("actual_cost") @db.Decimal(12, 2)

  quote         Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  display       DisplayCatalog?     @relation(fields: [displayId], references: [id], onDelete: Restrict)
  installMethod InstallMethod?      @relation(fields: [installMethodId], references: [id], onDelete: Restrict)
  serviceHours  ServiceHoursOption? @relation(fields: [serviceHoursId], references: [id], onDelete: Restrict)
  warranty      WarrantyOption?     @relation(fields: [warrantyId], references: [id], onDelete: Restrict)

  items QuoteLcdItem[]

  @@index([quoteId])
  @@map("quote_lcd_screens")
}

model QuoteLcdItem {
  id               BigInt      @id @default(autoincrement())
  quoteLcdScreenId BigInt      @map("quote_lcd_screen_id")
  displayId        BigInt?     @map("display_id")
  itemType         LcdItemType @map("item_type")
  description      String?
  qty              Decimal     @default(1) @db.Decimal(10, 2)
  unitCost         Decimal?    @map("unit_cost") @db.Decimal(12, 2)
  unitSell         Decimal?    @map("unit_sell") @db.Decimal(12, 2)
  /** Per-line discount (V2), a fraction 0..1 that reduces this item's extended SELL in the rollup + margin. Null = no discount. */
  discountPct      Decimal?    @map("discount_pct") @db.Decimal(5, 4)

  screen  QuoteLcdScreen  @relation(fields: [quoteLcdScreenId], references: [id], onDelete: Cascade)
  display DisplayCatalog? @relation(fields: [displayId], references: [id], onDelete: Restrict)

  @@index([quoteLcdScreenId])
  @@map("quote_lcd_items")
}

model QuoteMediaplayer {
  id            BigInt @id @default(autoincrement())
  quoteId       BigInt @map("quote_id")
  mediaplayerId BigInt @map("mediaplayer_id")
  qty           Int    @default(1)

  quote       Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  mediaplayer Mediaplayer @relation(fields: [mediaplayerId], references: [id], onDelete: Restrict)

  @@map("quote_mediaplayers")
}

model QuotePeripheral {
  id           BigInt @id @default(autoincrement())
  quoteId      BigInt @map("quote_id")
  peripheralId BigInt @map("peripheral_id")
  qty          Int    @default(1)

  quote      Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  peripheral Peripheral @relation(fields: [peripheralId], references: [id], onDelete: Restrict)

  @@map("quote_peripherals")
}

model QuoteManufacturedItem {
