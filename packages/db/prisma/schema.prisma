// QuoteZen data model — 58 tables, fully relational (no JSON blobs).
// Layers: A) auth & audit, B) reference/catalog (product master), C) quote transactional.
// See CLAUDE.md for the modelling decisions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────
enum QuoteStatus {
  draft
  in_review
  approved
  issued
  won
  lost
}

enum ScreenType {
  LED
  LCD
}

enum LicenceTier {
  low
  high
}

enum LedComponentType {
  controller
  led_peripheral
  mediaplayer
  mediaplayer_peripheral
}

enum AuditAction {
  create
  update
  delete
  status_change
}

enum LcdItemType {
  display
  mediaplayer
  bracket
  install
  labour
  location_fee
}

enum HypervsnRateCard {
  aud
  reseller_aud
  nzd
  reseller_nzd
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP A — Auth & audit
// ════════════════════════════════════════════════════════════════════════════════
model Role {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("roles")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  roleId       BigInt   @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  role          Role            @relation(fields: [roleId], references: [id])
  auditLogs     QuoteAuditLog[]
  revisions     QuoteRevision[]
  kbEntries     KbEntry[]
  viewerQuotes  QuoteViewer[]
  createdQuotes Quote[]         @relation("QuoteCreatedBy")
  updatedQuotes Quote[]         @relation("QuoteUpdatedBy")

  @@map("users")
}

model QuoteAuditLog {
  id          BigInt      @id @default(autoincrement())
  quoteId     BigInt      @map("quote_id")
  userId      BigInt      @map("user_id")
  action      AuditAction
  entityTable String      @map("entity_table")
  entityId    BigInt?     @map("entity_id")
  fieldName   String?     @map("field_name")
  oldValue    String?     @map("old_value")
  newValue    String?     @map("new_value")
  changedAt   DateTime    @default(now()) @map("changed_at")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([quoteId])
  @@map("quote_audit_log")
}

model QuoteRevision {
  id         BigInt   @id @default(autoincrement())
  quoteId    BigInt   @map("quote_id")
  revisionNo Int      @map("revision_no")
  label      String?
  // Immutable point-in-time snapshot of the full quote (header + screens + applied rule values +
  // computed outputs). A version snapshot is an audit artifact, not the live queryable model — so a
  // structured JSON document is the right shape here (P1-04.1), distinct from the relational tables.
  snapshot   Json?
  /** Grand total at snapshot time, for quick version-list display without parsing the snapshot. */
  grandTotal Decimal? @map("grand_total") @db.Decimal(12, 2)
  /** When this version restored an earlier one, the revision_no it was restored from. */
  restoredFrom Int?   @map("restored_from")
  createdById BigInt  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  quote     Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@unique([quoteId, revisionNo])
  @@map("quote_revisions")
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP B — Reference / catalog (product master)
// ════════════════════════════════════════════════════════════════════════════════
model Currency {
  id   BigInt  @id @default(autoincrement())
  code String  @unique
  name String?

  exchangeRate              ExchangeRate?
  seafreightRates           SeafreightRate[]
  installerRates            InstallerRate[]
  intlSupportRates          InternationalSupportRate[]
  intlInstallRates          InternationalInstallRate[]
  quotes                    Quote[]

  @@map("currencies")
}

model ExchangeRate {
  id         BigInt  @id @default(autoincrement())
  currencyId BigInt  @unique @map("currency_id")
  pairLabel  String? @map("pair_label")
  budgetRate Decimal @map("budget_rate") @db.Decimal(12, 6)
  liveRate   Decimal? @map("live_rate") @db.Decimal(12, 6)

  currency Currency @relation(fields: [currencyId], references: [id])

  @@map("exchange_rates")
}

model Setting {
  id    BigInt  @id @default(autoincrement())
  key   String  @unique
  label String
  value Decimal @db.Decimal(12, 6)
  unit  String?

  @@map("settings")
}

model SeafreightRate {
  id         BigInt  @id @default(autoincrement())
  label      String
  value      Decimal @db.Decimal(12, 2)
  currencyId BigInt? @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("seafreight_rates")
}

model FreightOption {
  id   BigInt   @id @default(autoincrement())
  name String
  rate Decimal? @db.Decimal(12, 2)

  ledScreens QuoteLedScreen[]

  @@map("freight_options")
}

model Location {
  id                BigInt  @id @default(autoincrement())
  name              String
  freightMultiplier Decimal @map("freight_multiplier") @db.Decimal(12, 4)
  freightMin        Decimal @map("freight_min") @db.Decimal(12, 2)
  frameFreight      Decimal @map("frame_freight") @db.Decimal(12, 2)
  trimFreight       Decimal @map("trim_freight") @db.Decimal(12, 2)
  hourlyUplift      Decimal @map("hourly_uplift") @db.Decimal(12, 2)

  quotes Quote[]

  @@map("locations")
}

model LedProduct {
  id               BigInt   @id @default(autoincrement())
  vendor           String?
  model            String
  serviceCategory  String?  @map("service_category")
  moduleWMm        Int?     @map("module_w_mm")
  moduleHMm        Int?     @map("module_h_mm")
  minCabinetWMm    Int?     @map("min_cabinet_w_mm")
  minCabinetHMm    Int?     @map("min_cabinet_h_mm")
  cabinetDepthMm   Int?     @map("cabinet_depth_mm")
  cabinetType      String?  @map("cabinet_type")
  pixelPitchH      Decimal? @map("pixel_pitch_h") @db.Decimal(6, 3)
  pixelPitchV      Decimal? @map("pixel_pitch_v") @db.Decimal(6, 3)
  brightnessNits   Int?     @map("brightness_nits")
  powerMaxW        Int?     @map("power_max_w")
  powerAvgW        Int?     @map("power_avg_w")
  kgPerSqm         Decimal? @map("kg_per_sqm") @db.Decimal(8, 2)
  shipDepthMm      Int?     @map("ship_depth_mm")
  volumetricModifier Decimal? @map("volumetric_modifier") @db.Decimal(6, 3)
  costPerSqmUsd    Decimal? @map("cost_per_sqm_usd") @db.Decimal(12, 2)
  modulePrice      Decimal? @map("module_price") @db.Decimal(12, 2)
  includesReceivers Boolean? @map("includes_receivers")
  gobIncluded      Boolean? @map("gob_included")
  packIncluded     Boolean? @map("pack_included")
  upgradeOptions   String?  @map("upgrade_options")
  mechanicalOptions String? @map("mechanical_options")
  serviceAccess    String?  @map("service_access")
  priceValidFrom   DateTime? @map("price_valid_from")

  commentary LedCommentary[]
  ledScreens QuoteLedScreen[]

  @@map("led_products")
}

model LedCommentary {
  id              BigInt  @id @default(autoincrement())
  serviceCategory String  @map("service_category")
  productCode     String  @map("product_code")
  commentary      String
  ledProductId    BigInt? @map("led_product_id")

  ledProduct LedProduct? @relation(fields: [ledProductId], references: [id])

  @@map("led_commentary")
}

model Controller {
  id        BigInt  @id @default(autoincrement())
  name      String
  type      String?
  maxPorts  Int?    @map("max_ports")
  maxPixels BigInt? @map("max_pixels")
  maxWidth  Int?    @map("max_width")
  price     Decimal @db.Decimal(12, 2)

  ledComponents QuoteLedComponent[]

  @@map("controllers")
}

model LedPeripheral {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)

  ledComponents QuoteLedComponent[]

  @@map("led_peripherals")
}

model GobOption {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)

  ledScreens QuoteLedScreen[]

  @@map("gob_options")
}

model TrimOption {
  id               BigInt  @id @default(autoincrement())
  name             String
  widthMultiplier  Decimal @map("width_multiplier") @db.Decimal(12, 4)
  heightMultiplier Decimal @map("height_multiplier") @db.Decimal(12, 4)

  ledScreens QuoteLedScreen[]

  @@map("trim_options")
}

model HangingBarOption {
  id              BigInt  @id @default(autoincrement())
  name            String
  widthMultiplier Decimal @map("width_multiplier") @db.Decimal(12, 4)

  ledScreens QuoteLedScreen[]

  @@map("hanging_bar_options")
}

model Frame {
  id            BigInt  @id @default(autoincrement())
  name          String
  price         Decimal @db.Decimal(12, 2)
  backcoverCost Decimal @default(0) @map("backcover_cost") @db.Decimal(12, 2)
  installHours  Decimal @default(0) @map("install_hours") @db.Decimal(6, 2)

  ledScreens QuoteLedScreen[]

  @@map("frames")
}

model EngineeringOption {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)

  ledScreens QuoteLedScreen[]

  @@map("engineering_options")
}

model InstallMethod {
  id              BigInt  @id @default(autoincrement())
  name            String
  wallRequirement String? @map("wall_requirement")
  powerDataNote   String? @map("power_data_note")

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("install_methods")
}

model AccessEquipment {
  id      BigInt  @id @default(autoincrement())
  name    String
  dayRate Decimal @map("day_rate") @db.Decimal(12, 2)

  ledScreens QuoteLedScreen[]

  @@map("access_equipment")
}

model WarrantyOption {
  id    BigInt @id @default(autoincrement())
  name  String
  years Int

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("warranty_options")
}

model ServiceHoursOption {
  id   BigInt @id @default(autoincrement())
  name String

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("service_hours_options")
}

model ScreenRatio {
  id         BigInt  @id @default(autoincrement())
  minValue   Decimal @map("min_value") @db.Decimal(8, 2)
  maxValue   Decimal @map("max_value") @db.Decimal(8, 2)
  ratioLabel String  @map("ratio_label")

  @@map("screen_ratios")
}

model Mediaplayer {
  id          BigInt  @id @default(autoincrement())
  name        String
  description String?
  cost        Decimal @db.Decimal(12, 2)

  ledComponents    QuoteLedComponent[]
  quoteMediaplayers QuoteMediaplayer[]

  @@map("mediaplayers")
}

model Peripheral {
  id          BigInt  @id @default(autoincrement())
  name        String
  description String?
  cost        Decimal @db.Decimal(12, 2)
  sourceUrl   String? @map("source_url")

  ledComponents    QuoteLedComponent[]
  quotePeripherals QuotePeripheral[]

  @@map("peripherals")
}

model DisplayCatalog {
  id          BigInt   @id @default(autoincrement())
  category    String
  subcategory String?
  sizeInch    Decimal? @map("size_inch") @db.Decimal(6, 1)
  model       String
  description String?
  usd         Decimal? @db.Decimal(12, 2)
  listAud     Decimal? @map("list_aud") @db.Decimal(12, 2)
  freight     Decimal  @default(0) @db.Decimal(12, 2)
  totalCost   Decimal? @map("total_cost") @db.Decimal(12, 2)
  margin      Decimal? @db.Decimal(8, 4)
  sell        Decimal? @db.Decimal(12, 2)

  lcdScreens QuoteLcdScreen[]
  lcdItems   QuoteLcdItem[]

  @@map("display_catalog")
}

model ImportCatalog {
  id          BigInt   @id @default(autoincrement())
  brand       String
  series      String?
  sizeInch    String?  @map("size_inch")
  model       String
  description String?
  cost        Decimal? @db.Decimal(12, 2)
  sell        Decimal? @db.Decimal(12, 2)
  partNumber  String?  @map("part_number")

  @@map("import_catalog")
}

model ManufacturedProduct {
  id         BigInt   @id @default(autoincrement())
  type       String
  sizeInch   String?  @map("size_inch")
  brightness Int?
  cost       Decimal? @db.Decimal(12, 2)
  sell       Decimal? @db.Decimal(12, 2)

  bom        ManufacturedBom[]
  quoteItems QuoteManufacturedItem[]

  @@map("manufactured_products")
}

model ManufacturedComponent {
  id   BigInt  @id @default(autoincrement())
  name String
  cost Decimal @db.Decimal(12, 2)

  bom ManufacturedBom[]

  @@map("manufactured_components")
}

model ManufacturedBom {
  id          BigInt  @id @default(autoincrement())
  productId   BigInt  @map("product_id")
  componentId BigInt  @map("component_id")
  qty         Decimal @default(1) @db.Decimal(10, 2)

  product   ManufacturedProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  component ManufacturedComponent @relation(fields: [componentId], references: [id])

  @@map("manufactured_bom")
}

model InstallerRate {
  id               BigInt   @id @default(autoincrement())
  region           String
  location         String?
  installer        String?
  lcd              Decimal? @db.Decimal(12, 2)
  led              Decimal? @db.Decimal(12, 2)
  bracket          Decimal? @db.Decimal(12, 2)
  customWorks      Decimal? @map("custom_works") @db.Decimal(12, 2)
  customAdditional Decimal? @map("custom_additional") @db.Decimal(12, 2)
  permit           Decimal? @db.Decimal(12, 2)
  disposal         Decimal? @db.Decimal(12, 2)
  eveningWorks     Decimal? @map("evening_works") @db.Decimal(12, 2)
  gst              Decimal? @db.Decimal(8, 4)
  currencyId       BigInt?  @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("installer_rates")
}

model LicenceComponent {
  id         BigInt     @id @default(autoincrement())
  component  String
  tier       LicenceTier
  screenType ScreenType @map("screen_type")
  value      Decimal    @db.Decimal(12, 2)

  quoteLicences QuoteLicence[]

  @@map("licence_components")
}

model HardwareSupportComponent {
  id         BigInt     @id @default(autoincrement())
  component  String
  tier       LicenceTier
  screenType ScreenType @map("screen_type")
  value      Decimal    @db.Decimal(12, 2)

  @@map("hardware_support_components")
}

model InternationalSupportRate {
  id              BigInt   @id @default(autoincrement())
  partner         String
  region          String
  rateLabel       String   @map("rate_label")
  localValue      Decimal? @map("local_value") @db.Decimal(12, 2)
  localCurrencyId BigInt?  @map("local_currency_id")
  audValue        Decimal? @map("aud_value") @db.Decimal(12, 2)
  sellValue       Decimal? @map("sell_value") @db.Decimal(12, 2)

  localCurrency Currency? @relation(fields: [localCurrencyId], references: [id])

  @@map("international_support_rates")
}

model InternationalInstallRate {
  id         BigInt  @id @default(autoincrement())
  partner    String
  region     String?
  rateLabel  String  @map("rate_label")
  cost       Decimal @db.Decimal(12, 2)
  currencyId BigInt? @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("international_install_rates")
}

model InternationalVat {
  id            BigInt  @id @default(autoincrement())
  region        String  @unique
  vatMultiplier Decimal @map("vat_multiplier") @db.Decimal(8, 4)

  @@map("international_vat")
}

model SoftwareActivity {
  id       BigInt  @id @default(autoincrement())
  activity String
  cost     Decimal @db.Decimal(12, 4)
  sell     Decimal @db.Decimal(12, 4)
  ratio    Decimal? @db.Decimal(8, 4)

  quoteItems QuoteSoftwareItem[]

  @@map("software_activities")
}

model AudioProduct {
  id        BigInt   @id @default(autoincrement())
  category  String
  name      String
  sourceUrl String?  @map("source_url")
  cost      Decimal? @db.Decimal(12, 2)
  sell      Decimal? @db.Decimal(12, 2)

  quoteItems QuoteAudioItem[]

  @@map("audio_products")
}

model MusicService {
  id       BigInt   @id @default(autoincrement())
  category String
  name     String
  cost     Decimal? @db.Decimal(12, 2)
  sell     Decimal? @db.Decimal(12, 2)
  sqmMin   Int?     @map("sqm_min")
  sqmMax   Int?     @map("sqm_max")

  quoteItems QuoteMusicItem[]

  @@map("music_services")
}

model HypervsnProduct {
  id           BigInt   @id @default(autoincrement())
  category     String
  name         String
  sellAud      Decimal? @map("sell_aud") @db.Decimal(12, 2)
  resellerAud  Decimal? @map("reseller_aud") @db.Decimal(12, 2)
  sellNzd      Decimal? @map("sell_nzd") @db.Decimal(12, 2)
  resellerNzd  Decimal? @map("reseller_nzd") @db.Decimal(12, 2)

  quoteItems QuoteHypervsnItem[]

  @@map("hypervsn_products")
}

model Client {
  id              BigInt   @id @default(autoincrement())
  name            String
  marginNote      String?  @map("margin_note")
  ledScreenNote   String?  @map("led_screen_note")
  gobNote         String?  @map("gob_note")
  mediaplayerNote String?  @map("mediaplayer_note")
  ratioNote       String?  @map("ratio_note")
  defaultMargin   Decimal? @map("default_margin") @db.Decimal(8, 4)
  // Structured overrides (P1-10) — replace today's free-text notes.
  preferredProductFamily String? @map("preferred_product_family")
  preferredPitchMm       Decimal? @map("preferred_pitch_mm") @db.Decimal(6, 3)
  /** Comma-separated component/family names to exclude for this client. */
  excludedComponents     String? @map("excluded_components")

  quotes Quote[]

  @@map("clients")
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP C — Quote transactional
// ════════════════════════════════════════════════════════════════════════════════
model Quote {
  id                    BigInt      @id @default(autoincrement())
  jobReference          String      @unique @map("job_reference")
  clientId              BigInt?     @map("client_id")
  locationId            BigInt?     @map("location_id")
  currencyId            BigInt      @map("currency_id")
  status                QuoteStatus @default(draft)
  resellerMarkup        Decimal     @default(0) @map("reseller_markup") @db.Decimal(8, 4)
  /** Optimistic-locking token; bumped on every mutation (P1-05.2). */
  lockVersion           Int         @default(0) @map("lock_version")
  validUntil            DateTime?   @map("valid_until")
  requestedShippingDate DateTime?   @map("requested_shipping_date")
  estimatedCost         Decimal?    @map("estimated_cost") @db.Decimal(12, 2)
  actualCost            Decimal?    @map("actual_cost") @db.Decimal(12, 2)
  totalEquipment        Decimal     @default(0) @map("total_equipment") @db.Decimal(12, 2)
  totalServices         Decimal     @default(0) @map("total_services") @db.Decimal(12, 2)
  totalRecurring        Decimal     @default(0) @map("total_recurring") @db.Decimal(12, 2)
  grandTotal            Decimal     @default(0) @map("grand_total") @db.Decimal(12, 2)
  createdById           BigInt      @map("created_by")
  updatedById           BigInt?     @map("updated_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  client    Client?   @relation(fields: [clientId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  currency  Currency  @relation(fields: [currencyId], references: [id])
  createdBy User      @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  updatedBy User?     @relation("QuoteUpdatedBy", fields: [updatedById], references: [id])

  kbEntry            KbEntry?
  viewers            QuoteViewer[]
  ledScreens         QuoteLedScreen[]
  lcdScreens         QuoteLcdScreen[]
  mediaplayers       QuoteMediaplayer[]
  peripherals        QuotePeripheral[]
  manufacturedItems  QuoteManufacturedItem[]
  audioItems         QuoteAudioItem[]
  musicItems         QuoteMusicItem[]
  hypervsnItems      QuoteHypervsnItem[]
  softwareItems      QuoteSoftwareItem[]
  licences           QuoteLicence[]
  terms              QuoteTerm[]
  auditLogs          QuoteAuditLog[]
  revisions          QuoteRevision[]

  @@index([clientId])
  @@index([status])
  @@map("quotes")
}

model QuoteLedScreen {
  id                  BigInt   @id @default(autoincrement())
  quoteId             BigInt   @map("quote_id")
  seq                 Int      @default(1)
  screenName          String?  @map("screen_name")
  ledProductId        BigInt?  @map("led_product_id")
  qty                 Int      @default(1)
  desiredWidthMm      Int?     @map("desired_width_mm")
  desiredHeightMm     Int?     @map("desired_height_mm")
  rotateCabinets      Boolean  @default(false) @map("rotate_cabinets")
  gobId               BigInt?  @map("gob_id")
  frameId             BigInt?  @map("frame_id")
  trimId              BigInt?  @map("trim_id")
  hangingBarId        BigInt?  @map("hanging_bar_id")
  engineeringId       BigInt?  @map("engineering_id")
  installMethodId     BigInt?  @map("install_method_id")
  freightOptionId     BigInt?  @map("freight_option_id")
  warrantyId          BigInt?  @map("warranty_id")
  serviceHoursId      BigInt?  @map("service_hours_id")
  accessEquipmentId   BigInt?  @map("access_equipment_id")
  marginOverride      Decimal? @map("margin_override") @db.Decimal(8, 4)
  // computed PI / spec outputs
  resolutionWpx       Int?     @map("resolution_w_px")
  resolutionHpx       Int?     @map("resolution_h_px")
  totalPixels         BigInt?  @map("total_pixels")
  weightKg            Decimal? @map("weight_kg") @db.Decimal(10, 2)
  powerAvgW           Int?     @map("power_avg_w")
  powerMaxW           Int?     @map("power_max_w")
  heatAvgBtu          Int?     @map("heat_avg_btu")
  heatMaxBtu          Int?     @map("heat_max_btu")
  cabinetDepthMm      Int?     @map("cabinet_depth_mm")
  recessSize          String?  @map("recess_size")
  freightKg           Decimal? @map("freight_kg") @db.Decimal(10, 2)
  labourHours         Decimal? @map("labour_hours") @db.Decimal(8, 2)
  // per-screen PI fields
  spareModulesPct     Decimal? @map("spare_modules_pct") @db.Decimal(6, 2)
  spareHubCard        Int?     @map("spare_hub_card")
  sparePowerSupply    Int?     @map("spare_power_supply")
  powerSupplySpec     String?  @map("power_supply_spec")
  cabinetSizes        String?  @map("cabinet_sizes")
  protectivePackage   String?  @map("protective_package")
  gobCoatingNote      String?  @map("gob_coating_note")
  bracketsNote        String?  @map("brackets_note")
  controllerSeenRef   String?  @map("controller_seen_ref")
  ledSize             String?  @map("led_size")
  dataSpec            String?  @map("data_spec")
  serviceAccess       String?  @map("service_access")
  physicalInstall     String?  @map("physical_install")
  powerAndData        String?  @map("power_and_data")
  estimatedCost       Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost          Decimal? @map("actual_cost") @db.Decimal(12, 2)
  // computed price outputs
  priceScreenMediaplayer Decimal? @map("price_screen_mediaplayer") @db.Decimal(12, 2)
  priceFrameTrim         Decimal? @map("price_frame_trim") @db.Decimal(12, 2)
  priceServices          Decimal? @map("price_services") @db.Decimal(12, 2)
  priceTotal             Decimal? @map("price_total") @db.Decimal(12, 2)

  quote           Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  ledProduct      LedProduct?         @relation(fields: [ledProductId], references: [id])
  gob             GobOption?          @relation(fields: [gobId], references: [id])
  frame           Frame?              @relation(fields: [frameId], references: [id])
  trim            TrimOption?         @relation(fields: [trimId], references: [id])
  hangingBar      HangingBarOption?   @relation(fields: [hangingBarId], references: [id])
  engineering     EngineeringOption?  @relation(fields: [engineeringId], references: [id])
  installMethod   InstallMethod?      @relation(fields: [installMethodId], references: [id])
  freightOption   FreightOption?      @relation(fields: [freightOptionId], references: [id])
  warranty        WarrantyOption?     @relation(fields: [warrantyId], references: [id])
  serviceHours    ServiceHoursOption? @relation(fields: [serviceHoursId], references: [id])
  accessEquipment AccessEquipment?    @relation(fields: [accessEquipmentId], references: [id])

  components     QuoteLedComponent[]
  costBreakdown  QuoteLedCostBreakdown[]

  @@index([quoteId])
  @@map("quote_led_screens")
}

model QuoteLedComponent {
  id               BigInt           @id @default(autoincrement())
  quoteLedScreenId BigInt           @map("quote_led_screen_id")
  componentType    LedComponentType @map("component_type")
  controllerId     BigInt?          @map("controller_id")
  ledPeripheralId  BigInt?          @map("led_peripheral_id")
  mediaplayerId    BigInt?          @map("mediaplayer_id")
  peripheralId     BigInt?          @map("peripheral_id")
  qty              Int              @default(1)
  unitCostSnapshot Decimal?         @map("unit_cost_snapshot") @db.Decimal(12, 2)
  unitSellSnapshot Decimal?         @map("unit_sell_snapshot") @db.Decimal(12, 2)

  screen        QuoteLedScreen @relation(fields: [quoteLedScreenId], references: [id], onDelete: Cascade)
  controller    Controller?    @relation(fields: [controllerId], references: [id])
  ledPeripheral LedPeripheral? @relation(fields: [ledPeripheralId], references: [id])
  mediaplayer   Mediaplayer?   @relation(fields: [mediaplayerId], references: [id])
  peripheral    Peripheral?    @relation(fields: [peripheralId], references: [id])

  @@index([quoteLedScreenId])
  @@map("quote_led_components")
}

model QuoteLedCostBreakdown {
  id               BigInt   @id @default(autoincrement())
  quoteLedScreenId BigInt   @map("quote_led_screen_id")
  lineLabel        String   @map("line_label")
  category         String?
  cost             Decimal? @db.Decimal(12, 2)
  sell             Decimal? @db.Decimal(12, 2)

  screen QuoteLedScreen @relation(fields: [quoteLedScreenId], references: [id], onDelete: Cascade)

  @@index([quoteLedScreenId])
  @@map("quote_led_cost_breakdown")
}

model QuoteLcdScreen {
  id                     BigInt   @id @default(autoincrement())
  quoteId                BigInt   @map("quote_id")
  seq                    Int      @default(1)
  screenName             String?  @map("screen_name")
  displayId              BigInt?  @map("display_id")
  installMethodId        BigInt?  @map("install_method_id")
  serviceHoursId         BigInt?  @map("service_hours_id")
  warrantyId             BigInt?  @map("warranty_id")
  priceScreenMediaplayer Decimal? @map("price_screen_mediaplayer") @db.Decimal(12, 2)
  priceBracketShroud     Decimal? @map("price_bracket_shroud") @db.Decimal(12, 2)
  priceServices          Decimal? @map("price_services") @db.Decimal(12, 2)
  priceTotal             Decimal? @map("price_total") @db.Decimal(12, 2)
  labourHours            Decimal? @map("labour_hours") @db.Decimal(8, 2)
  dataSpec               String?  @map("data_spec")
  serviceAccess          String?  @map("service_access")
  physicalInstall        String?  @map("physical_install")
  powerAndData           String?  @map("power_and_data")
  estimatedCost          Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost             Decimal? @map("actual_cost") @db.Decimal(12, 2)

  quote         Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  display       DisplayCatalog?     @relation(fields: [displayId], references: [id])
  installMethod InstallMethod?      @relation(fields: [installMethodId], references: [id])
  serviceHours  ServiceHoursOption? @relation(fields: [serviceHoursId], references: [id])
  warranty      WarrantyOption?     @relation(fields: [warrantyId], references: [id])

  items QuoteLcdItem[]

  @@index([quoteId])
  @@map("quote_lcd_screens")
}

model QuoteLcdItem {
  id               BigInt      @id @default(autoincrement())
  quoteLcdScreenId BigInt      @map("quote_lcd_screen_id")
  displayId        BigInt?     @map("display_id")
  itemType         LcdItemType @map("item_type")
  description      String?
  qty              Decimal     @default(1) @db.Decimal(10, 2)
  unitCost         Decimal?    @map("unit_cost") @db.Decimal(12, 2)
  unitSell         Decimal?    @map("unit_sell") @db.Decimal(12, 2)

  screen  QuoteLcdScreen  @relation(fields: [quoteLcdScreenId], references: [id], onDelete: Cascade)
  display DisplayCatalog? @relation(fields: [displayId], references: [id])

  @@index([quoteLcdScreenId])
  @@map("quote_lcd_items")
}

model QuoteMediaplayer {
