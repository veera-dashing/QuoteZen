model QuoteLicence {
  id                 BigInt      @id @default(autoincrement())
  quoteId            BigInt      @map("quote_id")
  licenceComponentId BigInt?     @map("licence_component_id")
  screenType         ScreenType  @map("screen_type")
  tier               LicenceTier
  qty                Int         @default(1)
  isInteractive      Boolean     @default(false) @map("is_interactive")

  quote            Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  licenceComponent LicenceComponent? @relation(fields: [licenceComponentId], references: [id], onDelete: Restrict)

  @@map("quote_licences")
}

model QuoteTerm {
  id      BigInt @id @default(autoincrement())
  quoteId BigInt @map("quote_id")
  seq     Int
  /** 'assumption' | 'exclusion' | 'term' — groups the line in the proposal (app-level enum). */
  kind    String @default("term")
  text    String

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_terms")
}

/**
 * Manually-captured risk for a quote (T4 / Workshop "Capability 2", FR-038–041). The risks half of
 * the assumptions & risks register; assumptions reuse `quote_terms` (kind=assumption). Manual capture
 * only — AI gap/risk detection stays deferred. Flows into the proposal PDF + PM handoff.
 */
model QuoteRisk {
  id          BigInt   @id @default(autoincrement())
  quoteId     BigInt   @map("quote_id")
  /** 'technical' | 'commercial' | 'delivery' (app-level enum). */
  category    String
  description String
  /** 'low' | 'medium' | 'high' (app-level enum). */
  severity    String
  mitigation  String?
  /** Display / save order (seq = array index). */
  seq         Int
  createdAt   DateTime @default(now()) @map("created_at")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_risks")
}

// Quote sharing — assign specific viewer users to a quote; they can read only quotes assigned to them.
model QuoteViewer {
  id        BigInt   @id @default(autoincrement())
  quoteId   BigInt   @map("quote_id")
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quoteId, userId])
  @@index([userId])
  @@map("quote_viewers")
}

// Knowledge-base capture (P1-19f): structured snapshot of a completed quote + its outcome. Storage
// only (no query/AI in Phase 1) — the corpus for future KB-similarity / learning. One row per quote.
model KbEntry {
  id            BigInt   @id @default(autoincrement())
  quoteId       BigInt   @unique @map("quote_id")
  jobReference  String   @map("job_reference")
  clientName    String?  @map("client_name")
  locationName  String?  @map("location_name")
  screenCount   Int      @map("screen_count")
  productModels String?  @map("product_models")
  grandTotal    Decimal  @map("grand_total") @db.Decimal(12, 2)
  margin        Decimal? @db.Decimal(8, 4)
  outcome       String
  capturedById  BigInt   @map("captured_by")
  capturedAt    DateTime @default(now()) @map("captured_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  quote      Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  capturedBy User  @relation(fields: [capturedById], references: [id])

  @@index([outcome])
  @@map("kb_entries")
}
