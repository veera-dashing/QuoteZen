  qty       Int    @default(1)

  quote   Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product ManufacturedProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("quote_manufactured_items")
}

model QuoteAudioItem {
  id             BigInt @id @default(autoincrement())
  quoteId        BigInt @map("quote_id")
  audioProductId BigInt @map("audio_product_id")
  qty            Int    @default(1)

  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  audioProduct AudioProduct @relation(fields: [audioProductId], references: [id], onDelete: Restrict)

  @@map("quote_audio_items")
}

model QuoteMusicItem {
  id             BigInt @id @default(autoincrement())
  quoteId        BigInt @map("quote_id")
  musicServiceId BigInt @map("music_service_id")
  qty            Int    @default(1)

  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  musicService MusicService @relation(fields: [musicServiceId], references: [id], onDelete: Restrict)

  @@map("quote_music_items")
