model QuoteHypervsnItem {
  id                BigInt           @id @default(autoincrement())
  quoteId           BigInt           @map("quote_id")
  hypervsnProductId BigInt           @map("hypervsn_product_id")
  qty               Int              @default(1)
  rateCard          HypervsnRateCard @default(aud) @map("rate_card")

  quote           Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  hypervsnProduct HypervsnProduct @relation(fields: [hypervsnProductId], references: [id], onDelete: Restrict)

  @@map("quote_hypervsn_items")
}

model QuoteSoftwareItem {
  id                 BigInt  @id @default(autoincrement())
  quoteId            BigInt  @map("quote_id")
  softwareActivityId BigInt  @map("software_activity_id")
  qty                Decimal @default(1) @db.Decimal(10, 2)

  quote            Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  softwareActivity SoftwareActivity @relation(fields: [softwareActivityId], references: [id], onDelete: Restrict)

  @@map("quote_software_items")
