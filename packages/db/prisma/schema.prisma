// QuoteZen data model — 58 tables, fully relational (no JSON blobs).
// Layers: A) auth & audit, B) reference/catalog (product master), C) quote transactional.
// See CLAUDE.md for the modelling decisions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────
enum QuoteStatus {
  draft
  in_review
  // Two-stage human review & approval (T1 / BR-001): a quote passes a technical review then a
  // commercial review before it can be approved and issued.
  technical_review
  commercial_review
  approved
  issued
  won
  lost
}

enum ScreenType {
  LED
  LCD
}

enum LicenceTier {
  low
  high
}

enum LedComponentType {
  controller
  led_peripheral
  mediaplayer
  mediaplayer_peripheral
}

enum AuditAction {
  create
  update
  delete
  status_change
}

enum LcdItemType {
  display
  mediaplayer
  bracket
  install
  labour
  location_fee
  warranty
}

enum HypervsnRateCard {
  aud
  reseller_aud
  nzd
  reseller_nzd
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP A — Auth & audit
// ════════════════════════════════════════════════════════════════════════════════
model Role {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("roles")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  roleId       BigInt   @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  // UI theme preference ('light' | 'dark'), self-service via PATCH /auth/me. Defaults to the app's
  // original dark palette so existing users are unaffected.
  themePreference String @default("dark") @map("theme_preference")
  createdAt    DateTime @default(now()) @map("created_at")

  role          Role            @relation(fields: [roleId], references: [id])
  auditLogs     QuoteAuditLog[]
  revisions     QuoteRevision[]
  reviews       QuoteReview[]   @relation("QuoteReviewReviewer")
  kbEntries     KbEntry[]
  viewerQuotes  QuoteViewer[]
  createdQuotes Quote[]         @relation("QuoteCreatedBy")
  updatedQuotes Quote[]         @relation("QuoteUpdatedBy")
  overrides     QuoteOverride[] @relation("QuoteOverrideCreatedBy")
  documents     QuoteDocument[] @relation("QuoteDocumentUploadedBy")
  adminAudit    AdminAuditLog[]

  @@map("users")
}

model QuoteAuditLog {
  id          BigInt      @id @default(autoincrement())
  quoteId     BigInt      @map("quote_id")
  userId      BigInt      @map("user_id")
  action      AuditAction
  entityTable String      @map("entity_table")
  entityId    BigInt?     @map("entity_id")
  fieldName   String?     @map("field_name")
  oldValue    String?     @map("old_value")
  newValue    String?     @map("new_value")
  changedAt   DateTime    @default(now()) @map("changed_at")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([quoteId])
  @@map("quote_audit_log")
}

// Append-only audit trail for high-sensitivity reference/catalog mutations (P1-06.6 / P1-07.6).
// Distinct from QuoteAuditLog (which is quote-scoped); this records admin CRUD + exports of
// catalog/settings tables, including the markup/margin editor.
model AdminAuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  tableName String   @map("table_name")
  recordId  String?  @map("record_id")
  action    String // 'create' | 'update' | 'delete' | 'export'
  // For update: { field: { old, new } }; create: created values; delete: prior values.
  changes   Json?
  changedAt DateTime @default(now()) @map("changed_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tableName])
  @@index([changedAt])
  @@map("admin_audit_log")
}

model QuoteRevision {
  id         BigInt   @id @default(autoincrement())
  quoteId    BigInt   @map("quote_id")
  revisionNo Int      @map("revision_no")
  label      String?
  // Immutable point-in-time snapshot of the full quote (header + screens + applied rule values +
  // computed outputs). A version snapshot is an audit artifact, not the live queryable model — so a
  // structured JSON document is the right shape here (P1-04.1), distinct from the relational tables.
  snapshot   Json?
  /** Grand total at snapshot time, for quick version-list display without parsing the snapshot. */
  grandTotal Decimal? @map("grand_total") @db.Decimal(12, 2)
  /** When this version restored an earlier one, the revision_no it was restored from. */
  restoredFrom Int?   @map("restored_from")
  createdById BigInt  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  quote     Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@unique([quoteId, revisionNo])
  @@map("quote_revisions")
}

/**
 * Two-stage review & approval record (T1 / BR-001, FR-102–110). Each row is an immutable approval
 * artifact: a reviewer's decision at one stage against ONE specific revision (`lockVersion` captured
 * at sign-off). Review rows are never deleted, so the full approval history is preserved across
 * revisions (FR-110). Issuing a quote requires an `approved` row at BOTH stages for the CURRENT
 * revision — see `recordReview` / `changeStatus`.
 */
model QuoteReview {
  id          BigInt   @id @default(autoincrement())
  quoteId     BigInt   @map("quote_id")
  /** The quote revision (lockVersion) this decision was made against. */
  lockVersion Int      @map("lock_version")
  stage       String // 'technical' | 'commercial'
  decision    String // 'approved' | 'rejected'
  reviewerId  BigInt   @map("reviewer_id")
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  quote    Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  reviewer User  @relation("QuoteReviewReviewer", fields: [reviewerId], references: [id])

  @@index([quoteId])
  @@map("quote_reviews")
}

// ════════════════════════════════════════════════════════════════════════════════
// GROUP B — Reference / catalog (product master)
// ════════════════════════════════════════════════════════════════════════════════
model Currency {
  id   BigInt  @id @default(autoincrement())
  code String  @unique
  name String?

  exchangeRate              ExchangeRate?
  seafreightRates           SeafreightRate[]
  installerRates            InstallerRate[]
  intlSupportRates          InternationalSupportRate[]
  intlInstallRates          InternationalInstallRate[]
  quotes                    Quote[]

  @@map("currencies")
}

model ExchangeRate {
  id         BigInt  @id @default(autoincrement())
  currencyId BigInt  @unique @map("currency_id")
  pairLabel  String? @map("pair_label")
  budgetRate Decimal @map("budget_rate") @db.Decimal(12, 6)
  liveRate   Decimal? @map("live_rate") @db.Decimal(12, 6)

  currency Currency @relation(fields: [currencyId], references: [id])

  @@map("exchange_rates")
}

model Setting {
  id    BigInt   @id @default(autoincrement())
  key   String   @unique
  label String
  /** Numeric value (markups, margins, rates). Null for text-only settings (see `valueText`). */
  value Decimal? @db.Decimal(12, 6)
  /** Text value for non-numeric settings (U0: comma-separated `size_tolerance_bands`). */
  valueText String? @map("value_text")
  unit  String?

  @@map("settings")
}

model SeafreightRate {
  id         BigInt  @id @default(autoincrement())
  label      String
  value      Decimal @db.Decimal(12, 2)
  currencyId BigInt? @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("seafreight_rates")
}

model FreightOption {
  id   BigInt   @id @default(autoincrement())
  name String
  rate Decimal? @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("freight_options")
}

model Location {
  id                BigInt  @id @default(autoincrement())
  name              String
  freightMultiplier Decimal @map("freight_multiplier") @db.Decimal(12, 4)
  freightMin        Decimal @map("freight_min") @db.Decimal(12, 2)
  frameFreight      Decimal @map("frame_freight") @db.Decimal(12, 2)
  trimFreight       Decimal @map("trim_freight") @db.Decimal(12, 2)
  hourlyUplift      Decimal @map("hourly_uplift") @db.Decimal(12, 2)

  quotes           Quote[]
  freightOverrides FreightOverride[]

  @@map("locations")
}

/**
 * AA6b — region/product-specific freight override (workshop rule #18: "global freight card + region-
 * & product-specific overrides; handle free-to-location-but-charged ~$90/screen"). Layered ON TOP of
 * the global weight-based freight card: when a row matches a LED screen, the screen's freight becomes
 * a flat `ratePerScreenAud` (per screen), replacing the computed weight-based location freight.
 *
 * Match rule: `locationId` null OR == the quote's location, AND `manufacturerId` null OR == the LED
 * product's manufacturer. Most-specific match wins (both set > one set > none). NO ROWS ARE SEEDED —
 * with an empty table this is a strict no-op and every existing price is unchanged.
 */
model FreightOverride {
  id               BigInt   @id @default(autoincrement())
  locationId       BigInt?  @map("location_id")
  manufacturerId   BigInt?  @map("manufacturer_id")
  ratePerScreenAud Decimal  @map("rate_per_screen_aud") @db.Decimal(12, 2)
  note             String?
  deprecated       Boolean  @default(false)

  location     Location?     @relation(fields: [locationId], references: [id])
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id])

  @@index([locationId])
  @@index([manufacturerId])
  @@map("freight_overrides")
}

/**
 * Hardware manufacturer (U0). Normalises the free-text `LedProduct.vendor` into a first-class
 * table so products can carry a real FK, and lead-time / sourcing priority live in one place.
 * `priority` orders manufacturers for future sourcing/ordering logic (lower = preferred); not
 * yet applied to pricing or selection — U0 is the schema + catalog foundation only.
 */
model Manufacturer {
  id           BigInt  @id @default(autoincrement())
  name         String  @unique
  priority     Int     @default(100)
  leadTimeDays Int?    @map("lead_time_days")
  deprecated   Boolean @default(false)

  ledProducts      LedProduct[]
  freightOverrides FreightOverride[]

  @@map("manufacturers")
}

model LedProduct {
  id               BigInt   @id @default(autoincrement())
  vendor           String?
  /** Normalised manufacturer FK (U0). `vendor` is kept for compat; backfilled by name on seed. */
  manufacturerId   BigInt?  @map("manufacturer_id")
  model            String
  serviceCategory  String?  @map("service_category")
  moduleWMm        Int?     @map("module_w_mm")
  moduleHMm        Int?     @map("module_h_mm")
  minCabinetWMm    Int?     @map("min_cabinet_w_mm")
  minCabinetHMm    Int?     @map("min_cabinet_h_mm")
  cabinetDepthMm   Int?     @map("cabinet_depth_mm")
  cabinetType      String?  @map("cabinet_type")
  pixelPitchH      Decimal? @map("pixel_pitch_h") @db.Decimal(6, 3)
  pixelPitchV      Decimal? @map("pixel_pitch_v") @db.Decimal(6, 3)
  brightnessNits   Int?     @map("brightness_nits")
  /** W0: 'indoor' | 'outdoor' | null. Null → config falls back to a brightness heuristic. */
  environment      String?  @map("environment")
  powerMaxW        Int?     @map("power_max_w")
  powerAvgW        Int?     @map("power_avg_w")
  kgPerSqm         Decimal? @map("kg_per_sqm") @db.Decimal(8, 2)
  shipDepthMm      Int?     @map("ship_depth_mm")
  volumetricModifier Decimal? @map("volumetric_modifier") @db.Decimal(6, 3)
  costPerSqmUsd    Decimal? @map("cost_per_sqm_usd") @db.Decimal(12, 2)
  modulePrice      Decimal? @map("module_price") @db.Decimal(12, 2)
  includesReceivers Boolean? @map("includes_receivers")
  gobIncluded      Boolean? @map("gob_included")
  packIncluded     Boolean? @map("pack_included")
  upgradeOptions   String?  @map("upgrade_options")
  mechanicalOptions String? @map("mechanical_options")
  serviceAccess    String?  @map("service_access")
  priceValidFrom   DateTime? @map("price_valid_from")
  /** Per-model recommendation priority (lower = preferred), admin-set. Secondary ranking key in the
      config engine, applied within a manufacturer. Default 100 ⇒ neutral (rank by fit) until changed. */
  priority         Int      @default(100)
  /** AA2 — component compatibility group. When set on BOTH a screen product and a selected controller
      or frame (bracket) with a DIFFERENT group, validation flags a mismatch (error). Null → no check. */
  compatibilityGroup String? @map("compatibility_group")
  deprecated       Boolean  @default(false) @map("deprecated")

  commentary LedCommentary[]
  ledScreens QuoteLedScreen[]
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)

  @@map("led_products")
}

model LedCommentary {
  id              BigInt  @id @default(autoincrement())
  serviceCategory String  @map("service_category")
  productCode     String  @map("product_code")
  commentary      String
  ledProductId    BigInt? @map("led_product_id")

  ledProduct LedProduct? @relation(fields: [ledProductId], references: [id])

  @@map("led_commentary")
}

model Controller {
  id        BigInt  @id @default(autoincrement())
  name      String
  type      String?
  maxPorts  Int?    @map("max_ports")
  maxPixels BigInt? @map("max_pixels")
  maxWidth  Int?    @map("max_width")
  price     Decimal @db.Decimal(12, 2)
  /** AA2 — component compatibility group (see LedProduct.compatibilityGroup). Null → no check. */
  compatibilityGroup String? @map("compatibility_group")
  deprecated Boolean @default(false) @map("deprecated")

  ledComponents QuoteLedComponent[]

  @@map("controllers")
}

model LedPeripheral {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledComponents QuoteLedComponent[]

  @@map("led_peripherals")
}

model GobOption {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("gob_options")
}

// AA4 — protective / gold coating add-on (workshop rule #21). Priced by area (cost/sqm × screen area,
// sold at the LED markup). Placeholder rates are commercial defaults (the workbook gives no rate).
model CoatingOption {
  id         BigInt  @id @default(autoincrement())
  name       String
  costPerSqm Decimal @map("cost_per_sqm") @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("coating_options")
}

model TrimOption {
  id               BigInt  @id @default(autoincrement())
  name             String
  widthMultiplier  Decimal @map("width_multiplier") @db.Decimal(12, 4)
  heightMultiplier Decimal @map("height_multiplier") @db.Decimal(12, 4)
  deprecated       Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("trim_options")
}

model HangingBarOption {
  id              BigInt  @id @default(autoincrement())
  name            String
  widthMultiplier Decimal @map("width_multiplier") @db.Decimal(12, 4)
  deprecated      Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("hanging_bar_options")
}

model Frame {
  id            BigInt  @id @default(autoincrement())
  name          String
  price         Decimal @db.Decimal(12, 2)
  backcoverCost Decimal @default(0) @map("backcover_cost") @db.Decimal(12, 2)
  installHours  Decimal @default(0) @map("install_hours") @db.Decimal(6, 2)
  /** AA2 — component compatibility group (see LedProduct.compatibilityGroup). Null → no check. */
  compatibilityGroup String? @map("compatibility_group")
  deprecated    Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("frames")
}

model EngineeringOption {
  id    BigInt  @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("engineering_options")
}

model InstallMethod {
  id              BigInt  @id @default(autoincrement())
  name            String
  wallRequirement String? @map("wall_requirement")
  powerDataNote   String? @map("power_data_note")
  /** X2: default install labour hours for this method (0 ⇒ no auto labour line). */
  defaultHours    Decimal  @default(0) @map("default_hours") @db.Decimal(12, 2)
  /** X2: hourly labour cost rate for this method; null ⇒ fall back to the `install_hourly_cost` setting ($95). */
  hourlyRateCost  Decimal? @map("hourly_rate_cost") @db.Decimal(12, 2)
  deprecated      Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("install_methods")
}

model AccessEquipment {
  id      BigInt  @id @default(autoincrement())
  name    String
  dayRate Decimal @map("day_rate") @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("access_equipment")
}

model WarrantyOption {
  id    BigInt @id @default(autoincrement())
  name  String
  years Int
  /** X2: extended-warranty cost per YEAR beyond the standard baseline (the first N years are baked into the display cost). */
  perYearCost Decimal @default(0) @map("per_year_cost") @db.Decimal(12, 2)
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("warranty_options")
}

model ServiceHoursOption {
  id   BigInt @id @default(autoincrement())
  name String
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]
  lcdScreens QuoteLcdScreen[]

  @@map("service_hours_options")
}

model ScreenRatio {
  id         BigInt  @id @default(autoincrement())
  minValue   Decimal @map("min_value") @db.Decimal(8, 2)
  maxValue   Decimal @map("max_value") @db.Decimal(8, 2)
  ratioLabel String  @map("ratio_label")
  deprecated Boolean @default(false) @map("deprecated")

  ledScreens QuoteLedScreen[]

  @@map("screen_ratios")
}

model Mediaplayer {
  id          BigInt  @id @default(autoincrement())
  name        String
  description String?
  cost        Decimal @db.Decimal(12, 2)
  deprecated  Boolean @default(false) @map("deprecated")

  ledComponents    QuoteLedComponent[]
  quoteMediaplayers QuoteMediaplayer[]

  @@map("mediaplayers")
}

model Peripheral {
  id          BigInt  @id @default(autoincrement())
  name        String
  description String?
  cost        Decimal @db.Decimal(12, 2)
  sourceUrl   String? @map("source_url")
  deprecated  Boolean @default(false) @map("deprecated")

  ledComponents    QuoteLedComponent[]
  quotePeripherals QuotePeripheral[]

  @@map("peripherals")
}

model DisplayCatalog {
  id          BigInt   @id @default(autoincrement())
  category    String
  subcategory String?
  sizeInch    Decimal? @map("size_inch") @db.Decimal(6, 1)
  model       String
  description String?
  usd         Decimal? @db.Decimal(12, 2)
  listAud     Decimal? @map("list_aud") @db.Decimal(12, 2)
  freight     Decimal  @default(0) @db.Decimal(12, 2)
  totalCost   Decimal? @map("total_cost") @db.Decimal(12, 2)
  margin      Decimal? @db.Decimal(8, 4)
  sell        Decimal? @db.Decimal(12, 2)
  deprecated  Boolean  @default(false) @map("deprecated")
  /** AA3a — LCD selection/constraint rule inputs (all nullable; rules stay cannot_evaluate on absence). */
  brand           String?  @map("brand")
  builtInAndroid  Boolean? @map("built_in_android")
  depthMm         Int?     @map("depth_mm")
  /** Bracket-category rows: supported panel size range (inches) + portrait capability. */
  minSizeIn       Int?     @map("min_size_in")
  maxSizeIn       Int?     @map("max_size_in")
  portraitCapable Boolean? @map("portrait_capable")

  lcdScreens QuoteLcdScreen[]
  lcdItems   QuoteLcdItem[]

  @@map("display_catalog")
}

model ImportCatalog {
  id          BigInt   @id @default(autoincrement())
  brand       String
  series      String?
  sizeInch    String?  @map("size_inch")
  model       String
  description String?
  cost        Decimal? @db.Decimal(12, 2)
  sell        Decimal? @db.Decimal(12, 2)
  partNumber  String?  @map("part_number")
  deprecated  Boolean  @default(false) @map("deprecated")

  @@map("import_catalog")
}

model ManufacturedProduct {
  id         BigInt   @id @default(autoincrement())
  type       String
  sizeInch   String?  @map("size_inch")
  brightness Int?
  cost       Decimal? @db.Decimal(12, 2)
  sell       Decimal? @db.Decimal(12, 2)
  deprecated Boolean  @default(false) @map("deprecated")

  bom        ManufacturedBom[]
  quoteItems QuoteManufacturedItem[]

  @@map("manufactured_products")
}

model ManufacturedComponent {
  id   BigInt  @id @default(autoincrement())
  name String
  cost Decimal @db.Decimal(12, 2)

  bom ManufacturedBom[]

  @@map("manufactured_components")
}

model ManufacturedBom {
  id          BigInt  @id @default(autoincrement())
  productId   BigInt  @map("product_id")
  componentId BigInt  @map("component_id")
  qty         Decimal @default(1) @db.Decimal(10, 2)

  product   ManufacturedProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  component ManufacturedComponent @relation(fields: [componentId], references: [id])

  @@map("manufactured_bom")
}

model InstallerRate {
  id               BigInt   @id @default(autoincrement())
  region           String
  location         String?
  installer        String?
  lcd              Decimal? @db.Decimal(12, 2)
  led              Decimal? @db.Decimal(12, 2)
  bracket          Decimal? @db.Decimal(12, 2)
  customWorks      Decimal? @map("custom_works") @db.Decimal(12, 2)
  customAdditional Decimal? @map("custom_additional") @db.Decimal(12, 2)
  permit           Decimal? @db.Decimal(12, 2)
  disposal         Decimal? @db.Decimal(12, 2)
  eveningWorks     Decimal? @map("evening_works") @db.Decimal(12, 2)
  gst              Decimal? @db.Decimal(8, 4)
  currencyId       BigInt?  @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("installer_rates")
}

model LicenceComponent {
  id         BigInt     @id @default(autoincrement())
  component  String
  tier       LicenceTier
  screenType ScreenType @map("screen_type")
  value      Decimal    @db.Decimal(12, 2)

  quoteLicences QuoteLicence[]

  @@map("licence_components")
}

model HardwareSupportComponent {
  id         BigInt     @id @default(autoincrement())
  component  String
  tier       LicenceTier
  screenType ScreenType @map("screen_type")
  value      Decimal    @db.Decimal(12, 2)

  @@map("hardware_support_components")
}

model InternationalSupportRate {
  id              BigInt   @id @default(autoincrement())
  partner         String
  region          String
  rateLabel       String   @map("rate_label")
  localValue      Decimal? @map("local_value") @db.Decimal(12, 2)
  localCurrencyId BigInt?  @map("local_currency_id")
  audValue        Decimal? @map("aud_value") @db.Decimal(12, 2)
  sellValue       Decimal? @map("sell_value") @db.Decimal(12, 2)

  localCurrency Currency? @relation(fields: [localCurrencyId], references: [id])

  @@map("international_support_rates")
}

model InternationalInstallRate {
  id         BigInt  @id @default(autoincrement())
  partner    String
  region     String?
  rateLabel  String  @map("rate_label")
  cost       Decimal @db.Decimal(12, 2)
  currencyId BigInt? @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  @@map("international_install_rates")
}

model InternationalVat {
  id            BigInt  @id @default(autoincrement())
  region        String  @unique
  vatMultiplier Decimal @map("vat_multiplier") @db.Decimal(8, 4)

  @@map("international_vat")
}

model SoftwareActivity {
  id       BigInt  @id @default(autoincrement())
  activity String
  cost     Decimal @db.Decimal(12, 4)
  sell     Decimal @db.Decimal(12, 4)
  ratio    Decimal? @db.Decimal(8, 4)
  deprecated Boolean @default(false) @map("deprecated")

  quoteItems QuoteSoftwareItem[]

  @@map("software_activities")
}

model AudioProduct {
