  category     String
  name         String
  sellAud      Decimal? @map("sell_aud") @db.Decimal(12, 2)
  resellerAud  Decimal? @map("reseller_aud") @db.Decimal(12, 2)
  sellNzd      Decimal? @map("sell_nzd") @db.Decimal(12, 2)
  resellerNzd  Decimal? @map("reseller_nzd") @db.Decimal(12, 2)
